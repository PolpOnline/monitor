		"formsnap": "2.0.1",
		"globals": "^17.4.0",
		"lucide-svelte": "^0.577.0",
		"mode-watcher": "^1.1.0",
		"openapi-fetch": "^0.17.0",
		"openapi-typescript": "^7.13.0",
